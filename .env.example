# GLM API 配置
# 从智谱 AI 平台获取: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# 可选：指定 API 端点（默认使用官方端点）
# GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4

# 成本预算配置（美元）
# COST_BUDGET_PER_TASK=5
# COST_BUDGET_PER_DAY=100
# COST_BUDGET_PER_MONTH=2000

# 日志级别
# LOG_LEVEL=info

# 调试模式
# DEBUG=false
